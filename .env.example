# App config
DATABASE_URL=postgresql+psycopg://concall:concall@localhost:5432/concall
# For a zero-infra run, use SQLite instead (vector search disabled):
# DATABASE_URL=sqlite:///./concall.db

# LLM provider: "stub" (default, deterministic, no network) or "azure_openai"
LLM_PROVIDER=stub
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Extraction provider: "stub" | "pdfplumber" | "azure_docintel"
EXTRACTION_PROVIDER=pdfplumber
AZURE_DOCINTEL_ENDPOINT=
AZURE_DOCINTEL_API_KEY=

# Where uploaded raw PDFs are stored (local dir in the scaffold; use Blob/S3 in prod)
BLOB_DIR=./data/blobs
